[Unit]
Description=Local file transfer web app
After=network.target

[Service]
Type=simple
User=alan
WorkingDirectory=/home/alan/file-transfer
EnvironmentFile=/home/alan/file-transfer/file-transfer.env
ExecStart=/usr/bin/node /home/alan/file-transfer/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
